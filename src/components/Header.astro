---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/features/", label: "Features" },
  { href: "/#pricing", label: "Pricing" },
  { href: "/chairs/", label: "Chair for Rent" },
  { href: "/security/", label: "Security" },
  { href: "/contact/", label: "Contact" },
];

function isActive(href: string) {
  return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 border-b border-gray-100/80 bg-white/90 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2" aria-label="Apptmint home">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-mint text-white">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
        </svg>
      </div>
      <span class="text-lg font-bold text-charcoal">appt<span class="text-mint">mint</span></span>
    </a>

    <nav class="hidden items-center gap-1 md:flex" aria-label="Main">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "rounded-lg px-3.5 py-2 text-sm font-medium transition-colors duration-200",
            isActive(link.href)
              ? "bg-mint/10 text-mint-dark"
              : "text-gray-500 hover:bg-gray-50 hover:text-charcoal",
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 md:flex">
      <a href="#" class="text-sm font-medium text-gray-500 transition-colors duration-200 hover:text-charcoal">Log In</a>
      <a href="/get-started/" class="rounded-lg bg-mint px-5 py-2.5 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-mint-dark hover:shadow-lg hover:shadow-mint/25">
        Start Free
      </a>
    </div>

    <button class="flex flex-col gap-1.5 p-2 md:hidden" id="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="block h-0.5 w-6 rounded bg-charcoal transition-all duration-200"></span>
      <span class="block h-0.5 w-6 rounded bg-charcoal transition-all duration-200"></span>
      <span class="block h-0.5 w-6 rounded bg-charcoal transition-all duration-200"></span>
    </button>
  </div>

  <div class="hidden border-t border-gray-100 bg-white md:hidden" id="mobile-nav">
    <nav class="mx-auto max-w-7xl px-4 py-4 sm:px-6">
      <div class="flex flex-col gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "rounded-lg px-4 py-3 text-sm font-medium transition-colors duration-200",
              isActive(link.href) ? "bg-mint/10 text-mint-dark" : "text-gray-500 hover:bg-gray-50",
            ]}
          >
            {link.label}
          </a>
        ))}
        <div class="mt-3 flex flex-col gap-2">
          <a href="#" class="rounded-lg border border-gray-200 px-4 py-3 text-center text-sm font-medium text-gray-600">Log In</a>
          <a href="/get-started/" class="rounded-lg bg-mint px-4 py-3 text-center text-sm font-semibold text-white">Start Free</a>
        </div>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("mobile-toggle") as HTMLButtonElement;
  const nav = document.getElementById("mobile-nav") as HTMLElement;
  const bars = toggle?.querySelectorAll("span");

  toggle?.addEventListener("click", () => {
    const open = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!open));
    nav.classList.toggle("hidden");
    if (bars) {
      bars[0].classList.toggle("translate-y-2");
      bars[0].classList.toggle("rotate-45");
      bars[1].classList.toggle("opacity-0");
      bars[2].classList.toggle("-translate-y-2");
      bars[2].classList.toggle("-rotate-45");
    }
  });
</script>
