---
const year = new Date().getFullYear();
---

<!-- Footer CTA -->
<section class="relative overflow-hidden bg-charcoal py-24">
  <div class="absolute inset-0 bg-gradient-to-br from-mint/15 via-transparent to-accent/10"></div>
  <div class="relative mx-auto max-w-3xl px-4 text-center sm:px-6">
    <h2 class="text-3xl font-black text-white sm:text-4xl">Ready to run your business without the chaos?</h2>
    <p class="mx-auto mt-4 max-w-lg text-lg leading-relaxed text-gray-300">
      Start free today. We'll help you get set up.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a href="#" class="rounded-lg bg-mint px-8 py-4 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-mint-dark hover:shadow-lg hover:shadow-mint/25">
        Start Free 30 Days
      </a>
      <a href="/contact/" class="rounded-lg border-2 border-white/20 px-8 py-4 text-sm font-semibold text-white transition-all duration-200 hover:border-mint hover:text-mint">
        Book a Demo
      </a>
    </div>
  </div>
</section>

<footer class="bg-charcoal border-t border-white/5 pt-16 pb-10">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <div class="flex items-center gap-2">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-mint text-white">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" />
            </svg>
          </div>
          <span class="text-lg font-bold text-white">appt<span class="text-mint">mint</span></span>
        </div>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-gray-400">
          Built for UK appointment businesses.
        </p>
        <a href="https://www.instagram.com/apptmint" target="_blank" rel="noopener noreferrer" class="mt-4 inline-flex items-center gap-2 text-sm text-gray-400 transition-colors hover:text-white" aria-label="Follow apptmint on Instagram">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
          @apptmint
        </a>
      </div>

      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">Product</h4>
        <ul class="space-y-3">
          <li><a href="/features/" class="text-sm text-gray-400 transition-colors hover:text-white">Features</a></li>
          <li><a href="/pricing/" class="text-sm text-gray-400 transition-colors hover:text-white">Pricing</a></li>
          <li><a href="/security/" class="text-sm text-gray-400 transition-colors hover:text-white">Security</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">Company</h4>
        <ul class="space-y-3">
          <li><a href="/contact/" class="text-sm text-gray-400 transition-colors hover:text-white">Contact</a></li>
          <li><a href="/privacy/" class="text-sm text-gray-400 transition-colors hover:text-white">Privacy</a></li>
          <li><a href="/terms/" class="text-sm text-gray-400 transition-colors hover:text-white">Terms</a></li>
        </ul>
      </div>

      <div>
        <h4 class="mb-4 text-xs font-bold uppercase tracking-[0.2em] text-gray-400">Solutions</h4>
        <ul class="space-y-3">
          <li><a href="/solutions/physiotherapy/" class="text-sm text-gray-400 transition-colors hover:text-white">Physiotherapy</a></li>
          <li><a href="/solutions/psychology/" class="text-sm text-gray-400 transition-colors hover:text-white">Psychology & Therapy</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-center gap-4 border-t border-white/10 pt-8">
      <span class="rounded-md border border-white/10 px-3 py-1 text-xs text-gray-500">ICO Registered</span>
      <span class="rounded-md border border-white/10 px-3 py-1 text-xs text-gray-500">GDPR Ready</span>
      <span class="rounded-md border border-white/10 px-3 py-1 text-xs text-gray-500">HMRC MTD Compliant</span>
      <span class="rounded-md border border-white/10 px-3 py-1 text-xs text-gray-500">Stripe Verified Partner</span>
    </div>

    <div class="mt-6 text-center">
      <p class="text-sm text-gray-500">&copy; {year} Apptmint Ltd. All rights reserved.</p>
    </div>
  </div>
</footer>
