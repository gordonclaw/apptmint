---
import BaseLayout from "../layouts/BaseLayout.astro";
import ShopOnboarding from "../components/ShopOnboarding";
---

<BaseLayout
  title="Set Up Your Shop | Apptmint"
  description="Set up your barbershop or salon on Apptmint. Enter your opening hours, staff, services and pricing in under 10 minutes."
>
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-block rounded-full bg-mint/20 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-mint-light">Setup</span>
        <h1 class="mt-4 text-4xl font-black text-white sm:text-5xl">Set up your shop</h1>
        <p class="mx-auto mt-4 max-w-lg text-lg leading-relaxed text-gray-300">
          Tell us about your shop, your hours, your team, and your services. Takes about 10 minutes. We'll get you live within one working day.
        </p>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <ShopOnboarding client:load />

      <!-- Netlify fallback form -->
      <form name="shop-onboarding" data-netlify="true" netlify-honeypot="bot-field" hidden>
        <input name="shop_name" /><input name="city" /><input name="postcode" />
        <input name="phone" /><input name="email" /><input name="business_type" />
        <input name="staff_count" /><input name="services_count" /><input name="pricing_rules_count" />
        <textarea name="full_data"></textarea>
      </form>
    </div>
  </section>
</BaseLayout>
