---
import BaseLayout from "../layouts/BaseLayout.astro";
import ChairForm from "../components/ChairForm";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Chair for Rent - Apptmint",
  description: "Free chair rental marketplace for UK barbers, hairdressers and salons. List your empty chair or find one near you.",
  provider: {
    "@type": "Organization",
    name: "Apptmint",
    url: "https://apptmint.co.uk",
  },
  areaServed: "GB",
  isRelatedTo: {
    "@type": "Product",
    name: "Barber Chair Rental",
  },
};
---

<BaseLayout
  title="Chair for Rent | Free Barber & Salon Chair Marketplace | Apptmint"
  description="List your empty barber chair or find one near you. Free marketplace for UK barbers, hairdressers and salons. No commission, no fees."
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <span class="inline-block rounded-lg bg-mint/20 px-3 py-1 text-xs font-bold uppercase tracking-widest text-mint-light">Free Marketplace</span>
        <h1 class="mt-4 text-4xl font-black text-white sm:text-5xl">Chair for Rent</h1>
        <p class="mx-auto mt-4 max-w-lg text-lg leading-relaxed text-gray-300">
          Got an empty chair? List it for free. Looking for a chair? Browse what's
          available near you. No commission, no fees, no middleman.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        <div class="text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-mint text-lg font-bold text-white">1</div>
          <h3 class="mt-4 font-bold text-charcoal">Post your ad</h3>
          <p class="mt-1 text-sm text-gray-500">Shop owners list their chairs. Freelance barbers post what they're looking for.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-mint text-lg font-bold text-white">2</div>
          <h3 class="mt-4 font-bold text-charcoal">Browse and match</h3>
          <p class="mt-1 text-sm text-gray-500">Filter by area, days, and price. Find the right fit without the legwork.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-mint text-lg font-bold text-white">3</div>
          <h3 class="mt-4 font-bold text-charcoal">Agree and get started</h3>
          <p class="mt-1 text-sm text-gray-500">Connect directly. No commission, no middleman. Just two people making a deal.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Example listings -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <!-- Shop owners -->
        <div>
          <h2 class="mb-6 text-xl font-black text-charcoal">Shop owners with chairs</h2>
          <div class="space-y-4">
            {[
              { shop: "Sharp Cuts", area: "Camden", chair: "Chair 3", days: "Tue & Wed", price: "40" },
              { shop: "Blade & Fade", area: "Shoreditch", chair: "Chair 2", days: "Weekdays", price: "50" },
              { shop: "The Parlour", area: "Brixton", chair: "Chair 1", days: "Mon, Thu, Fri", price: "35" },
            ].map((listing) => (
              <div class="flex items-center justify-between rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
                <div class="flex items-center gap-4">
                  <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-mint/10 text-sm font-bold text-mint-dark">
                    {listing.shop.split(" ").map((w) => w[0]).join("").slice(0, 2)}
                  </div>
                  <div>
                    <p class="font-semibold text-charcoal">{listing.shop}, {listing.area}</p>
                    <p class="text-sm text-gray-400">{listing.chair} -- {listing.days}</p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-lg font-black text-charcoal">&pound;{listing.price}</p>
                  <p class="text-xs text-gray-400">/day</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Freelancers -->
        <div>
          <h2 class="mb-6 text-xl font-black text-charcoal">Barbers looking for a chair</h2>
          <div class="space-y-4">
            {[
              { name: "Marcus T.", area: "East London", days: "Mon-Wed", budget: "45", exp: "8 years", note: "Specialises in fades" },
              { name: "Priya K.", area: "South London", days: "Sat & Sun", budget: "55", exp: "5 years", note: "Unisex stylist" },
              { name: "Dan R.", area: "North London", days: "Any day", budget: "35", exp: "1 year", note: "Newly qualified, keen to learn" },
            ].map((barber) => (
              <div class="flex items-center justify-between rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
                <div class="flex items-center gap-4">
                  <div class="flex h-11 w-11 items-center justify-center rounded-lg bg-accent/10 text-sm font-bold text-accent">
                    {barber.name.split(" ").map((w) => w[0]).join("")}
                  </div>
                  <div>
                    <p class="font-semibold text-charcoal">{barber.name} -- {barber.area}</p>
                    <p class="text-sm text-gray-400">{barber.days} -- {barber.exp} -- {barber.note}</p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-sm text-gray-400">up to</p>
                  <p class="text-lg font-black text-charcoal">&pound;{barber.budget}<span class="text-xs font-normal text-gray-400">/day</span></p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sign up form -->
  <section class="bg-white py-20" id="list">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12 text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">Get Listed</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">List your chair or find one</h2>
        <p class="mx-auto mt-4 max-w-md text-gray-500">
          Completely free for all barbers and shop owners. No fees, no commission,
          no hidden costs. Ever.
        </p>
      </div>

      <ChairForm client:load />

      <!-- Netlify hidden form for detection -->
      <form name="chair-rental" data-netlify="true" netlify-honeypot="bot-field" hidden>
        <input name="type" />
        <input name="name" />
        <input name="email" />
        <input name="phone" />
        <input name="location" />
        <input name="postcode" />
        <input name="days" />
        <input name="shop_name" />
        <input name="chairs_available" />
        <input name="price_per_day" />
        <input name="description" />
        <input name="max_budget" />
        <input name="experience_years" />
        <input name="specialities" />
        <input name="has_own_tools" />
        <input name="has_own_clients" />
        <input name="bio" />
      </form>
    </div>
  </section>

  <!-- Why free -->
  <section class="bg-gray-50 py-16">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-2xl font-black text-charcoal">Why is this free?</h2>
      <p class="mx-auto mt-4 max-w-lg text-gray-500">
        We're building Apptmint -- the all-in-one platform for appointment businesses.
        The chair marketplace is our way of giving back to the industry and connecting
        with shops and barbers who might benefit from the full platform when it launches.
        No strings attached.
      </p>
      <a href="/" class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-mint transition-colors hover:text-mint-dark">
        Learn about Apptmint
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
      </a>
    </div>
  </section>
</BaseLayout>
