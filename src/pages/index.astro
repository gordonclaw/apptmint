        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Built around your speciality</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: "Physiotherapy", desc: "Packs, protocols, room allocation, clinical notes. No Excel.", href: "/solutions/physiotherapy/", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>' },
          { title: "Psychology & Therapy", desc: "Private notes per therapist, consent forms, GDPR and data isolation.", href: "/solutions/psychology/", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>' },
          { title: "Beauty & Hair", desc: "Staff commissions, product stock, chair rental model.", href: "#", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>' },
          { title: "Personal Training", desc: "Session packs, outdoor/gym locations, client progress tracking.", href: "#", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>' },
        ].map((v) => (
          <a href={v.href} class="group flex flex-col rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-mint/10 text-mint transition-all duration-300 group-hover:bg-mint group-hover:text-white">
              <div class="h-5 w-5" set:html={v.icon} />
            </div>
            <h3 class="font-bold text-charcoal">{v.title}</h3>
            <p class="mt-1 flex-1 text-sm leading-relaxed text-gray-500">{v.desc}</p>
            {v.href !== "#" ? (
              <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-mint transition-all duration-200 group-hover:gap-2.5">Learn more <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></span>
            ) : (
              <span class="mt-4 text-xs font-medium text-gray-300">Coming soon</span>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

