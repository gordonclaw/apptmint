        {[
          { quote: "We cut our admin time in half within the first month. The invoicing alone is worth it.", name: "Dr. Claire Hughes", role: "Physiotherapy Clinic, Bristol" },
          { quote: "Clients love booking through WhatsApp. Mint handles 80% of our enquiries without us lifting a finger.", name: "James Carter", role: "Sports Therapy, Leeds" },
          { quote: "Finally, one system that does everything. No more juggling five different apps.", name: "Priya Patel", role: "Psychology Practice, London" },
