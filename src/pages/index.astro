            <a href="#" class:list={["mt-8 block rounded-lg py-3 text-center text-sm font-semibold transition-all duration-200", plan.highlight ? "bg-mint text-white hover:bg-mint-dark hover:shadow-lg hover:shadow-mint/25" : "border-2 border-charcoal text-charcoal hover:bg-charcoal hover:text-white"]}>Start Free Trial</a>
          </div>
