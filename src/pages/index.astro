        <div class="mt-6 space-y-3">
          {[
            { name: "Cliniko", price: "&pound;75/mo", note: "no WhatsApp, no AI" },
            { name: "Fresha", price: "20% commission", note: "per transaction" },
            { name: "Booksy", price: "&pound;40/mo + &pound;5/staff", note: "adds up fast" },
            { name: "Nearcut", price: "&pound;10/staff/mo", note: "barber-only, limited features" },
            { name: "Setmore", price: "&pound;39/mo", note: "no UK invoicing compliance" },
