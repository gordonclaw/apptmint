      </div>
      <div class="mx-auto mt-14 grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3">
        {[
          { name: "Starter", price: "29", desc: "Solo practitioner. Core scheduling + payments.", features: ["Smart calendar", "Online booking page", "Stripe payments", "MTD invoicing", "Email reminders", "1 staff member"], highlight: false },
          { name: "Growth", price: "59", desc: "Small team. Adds CRM, reminders, packs.", features: ["Everything in Starter", "Up to 5 staff", "Client CRM & profiles", "WhatsApp/SMS reminders", "Session packs & subscriptions", "Business reports"], highlight: true, badge: "Most Popular" },
          { name: "Pro", price: "99", desc: "Multi-staff. Payroll, reports, Mint AI, API.", features: ["Everything in Growth", "Unlimited staff", "Mint AI receptionist", "Payroll & commissions", "Stock management", "API & webhook access", "Priority support"], highlight: false },
