---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqItems = [
  { q: "How long does setup take?", a: "Most businesses are up and running in under an hour. We'll help you import your existing data and configure your calendar." },
  { q: "Do you migrate my existing data?", a: "Yes. We'll import your client list, appointment history, and any other data from your current system at no extra cost." },
  { q: "Is invoicing really HMRC/MTD compliant?", a: "Yes. Invoices are auto-generated with correct VAT handling, sequential numbering, and digital record-keeping that meets Making Tax Digital requirements." },
  { q: "How do I pay for Apptmint?", a: "Monthly subscription via card. No long-term contracts. Cancel anytime from your dashboard." },
  { q: "Can clients book online?", a: "Yes. You get a branded booking page and an embeddable widget for your website. Clients can book 24/7 without calling." },
  { q: "Does it work for multiple locations?", a: "Yes. The Pro plan supports multiple locations with separate calendars, staff, and reporting per site." },
  { q: "How do you reduce no-shows?", a: "Automatic WhatsApp and SMS reminders with one-tap confirmation. You can also collect deposits at booking to protect your time." },
  { q: "How is my data kept secure?", a: "All data is encrypted at rest and in transit. We're ICO registered, GDPR compliant, and hosted on UK/EU infrastructure. See our security page for details." },
  { q: "Can I integrate with my existing tools?", a: "We integrate with WhatsApp Business API out of the box. More integrations are on the roadmap." },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "Apptmint",
    url: "https://apptmint.co.uk",
    applicationCategory: "BusinessApplication",
    operatingSystem: "Web",
    description: "Booking system for UK barbers and hairdressers. WhatsApp bookings, reminders, auto-rebooking, gift vouchers and more.",
    offers: {
      "@type": "AggregateOffer",
      priceCurrency: "GBP",
      lowPrice: "9",
      highPrice: "19",
      offerCount: "2",
    },
    featureList: [
      "Online booking",
      "WhatsApp booking and reminders",
      "WhatsApp bookings",
      "MTD-compliant invoicing",
      "Client CRM",
      "Session packs and subscriptions",
      "Payroll and commissions",
      "AI receptionist",
      "Multi-location support",
      "GDPR compliant",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
];
---

<BaseLayout
  title="Apptmint | Appointment Booking Software for Barbers, Salons & Clinics | UK"
  description="Booking system for UK barbers and hairdressers. WhatsApp bookings, online booking page, auto-rebooking, reminders, gift vouchers. From £9/month. No contracts, no commission."
  schema={schema}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-charcoal pt-20 pb-24">
    <div class="absolute inset-0 bg-gradient-to-br from-mint/10 via-transparent to-accent/5"></div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
        <!-- Left: copy -->
        <div>
          <span class="inline-block rounded-full bg-mint/20 px-4 py-1.5 text-xs font-bold uppercase tracking-widest text-mint-light">Coming Soon</span>
          <h1 class="mt-6 text-4xl font-black leading-tight text-white sm:text-5xl lg:text-[3.5rem]">
            Bookings Made Simple for
            <span class="relative inline-block overflow-hidden align-bottom" style="height:1.2em;width:auto;">
              <span class="word-rotator flex flex-col">
                <span class="text-mint-light">Barbers</span>
                <span class="text-mint-light">Hairdressers</span>
                <span class="text-mint-light">Salons</span>
                <span class="text-mint-light">Physios</span>
                <span class="text-mint-light">Therapists</span>
                <span class="text-mint-light">Barbers</span>
              </span>
            </span>
            <span class="sr-only">Appointment Businesses</span>
          </h1>
          <p class="mt-6 max-w-lg text-lg leading-relaxed text-gray-300">
            No contracts. No commission. No per-booking fees. Just a simple booking system that works where your customers already are.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a href="/get-started/" class="rounded-lg bg-mint px-8 py-4 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-mint-dark hover:shadow-lg hover:shadow-mint/25">
              Start Free (30 days)
            </a>
            <a href="/features/" class="rounded-lg border-2 border-white/20 px-8 py-4 text-sm font-semibold text-white transition-all duration-200 hover:border-mint hover:text-mint">
              See Features
            </a>
          </div>
          <div class="mt-8 flex flex-wrap gap-6 text-sm text-gray-400">
            {["No contracts", "No commission", "Cancel anytime", "GDPR ready"].map((t) => (
              <span class="flex items-center gap-1.5">
                <svg class="h-4 w-4 text-mint" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {t}
              </span>
            ))}
          </div>
        </div>

        <!-- Right: WhatsApp booking mock -->
        <div class="hidden lg:block">
          <div class="mx-auto max-w-sm">
            <div class="rounded-2xl border border-white/10 bg-[#e5ddd5] p-4 shadow-2xl">
              <!-- WhatsApp header -->
              <div class="mb-3 flex items-center gap-3 rounded-xl bg-[#075e54] px-4 py-3">
                <div class="flex h-9 w-9 items-center justify-center rounded-full bg-mint text-xs font-bold text-white">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                </div>
                <div><p class="text-sm font-semibold text-white">Sharp Cuts</p><p class="text-[10px] text-green-200">via Apptmint</p></div>
              </div>
              <!-- Messages -->
              <div class="space-y-2">
                <!-- Booking confirmation -->
                <div class="mr-auto w-[85%] rounded-lg bg-white px-3 py-2.5 shadow-sm">
                  <p class="text-xs font-bold text-[#075e54]">Booking Confirmed</p>
                  <p class="mt-1.5 text-sm leading-relaxed text-gray-800">
                    Hi John, your haircut with Mike at Sharp Cuts is booked for <strong>Sat 15 Mar at 3:00 PM</strong>.
                  </p>
                  <div class="mt-3 grid grid-cols-3 gap-1.5">
                    <button class="rounded-md bg-[#25D366] px-2 py-1.5 text-xs font-semibold text-white">Confirm</button>
                    <button class="rounded-md bg-gray-100 px-2 py-1.5 text-xs font-medium text-gray-600">Reschedule</button>
                    <button class="rounded-md bg-gray-100 px-2 py-1.5 text-xs font-medium text-gray-600">Cancel</button>
                  </div>
                  <p class="mt-2 text-right text-[10px] text-gray-400">14:32</p>
                </div>
                <!-- Customer confirms -->
                <div class="ml-auto w-3/5 rounded-lg bg-[#dcf8c6] px-3 py-2 shadow-sm">
                  <p class="text-sm text-gray-800">Confirm</p>
                  <p class="text-right text-[10px] text-gray-400">14:33</p>
                </div>
                <!-- System response -->
                <div class="mr-auto w-[85%] rounded-lg bg-white px-3 py-2.5 shadow-sm">
                  <p class="text-sm leading-relaxed text-gray-800">
                    Great, see you Saturday! We'll send a reminder tomorrow.
                  </p>
                  <p class="mt-1 text-right text-[10px] text-gray-400">14:33</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem strip marquee -->
  <section class="overflow-hidden border-y border-gray-100 bg-gray-50 py-4">
    <div class="flex animate-marquee whitespace-nowrap">
      {[...Array(2)].map(() => (
        <>
          {["Missed appointments costing you money", "Juggling WhatsApp, spreadsheets and paper", "Clients booking outside office hours", "No-shows with no warning", "Staff holidays causing chaos"].map((t) => (
            <><span class="mx-8 text-sm font-medium text-gray-400">{t}</span><span class="text-gray-300">|</span></>
          ))}
        </>
      ))}
    </div>
  </section>

  <!-- Problems -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-red-400">The Problem</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Sound familiar?</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {[
          { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>', title: "Too many tools", desc: "Excel, WhatsApp, a notes app and a payment link. Nothing talks to anything else." },
          { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>', title: "No-shows with no warning", desc: "No automatic reminders means empty slots and lost revenue." },
          { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>', title: "Bookings only when you're available", desc: "Every appointment needs someone to pick up the phone." },
          { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>', title: "Holidays cause chaos", desc: "Staff takes a day off and nobody tells the customers who are booked in." },
          { icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>', title: "No idea how the business is doing", desc: "No dashboard, no reports, just gut feel." },
        ].map((p) => (
          <div class="rounded-2xl border border-red-100 bg-red-50/50 p-6 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-red-100 text-red-500">
              <div class="h-5 w-5" set:html={p.icon} />
            </div>
            <h3 class="font-bold text-charcoal">{p.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500">{p.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="bg-gray-50 py-20" id="features">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">Features</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">What you get</h2>
      </div>
      <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { title: "WhatsApp Bookings", desc: "Customers book, confirm and reschedule on WhatsApp. No app needed.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>' },
          { title: "Online Booking Page", desc: "Your own page, live 24/7. Share the link anywhere.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>' },
          { title: "Auto-Rebooking", desc: "Set recurring bookings. Every 4 weeks, every 6. Clients never forget.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>' },
          { title: "Smart Reminders", desc: "Automatic reminders the day before. One tap to confirm. Fewer no-shows.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>' },
          { title: "Smart Discovery", desc: "Fully booked? Show available slots at nearby partner shops.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>' },
          { title: "Sick Day Handling", desc: "One tap to notify affected customers and offer rebooking or substitutes.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><line x1="12" y1="2" x2="12" y2="4"/></svg>' },
          { title: "Gift Vouchers", desc: "Sell online. Customers buy as gifts, redeem at your shop.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="8" width="18" height="13" rx="2"/><path d="M12 8V21"/><path d="M3 12h18"/></svg>' },
          { title: "Staff Preferences", desc: "Customers pick their barber. If off, suggest their chosen substitute.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/></svg>' },
          { title: "Holiday Management", desc: "Log holidays. Bookings blocked automatically. Customers notified.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' },
          { title: "No-Show Tracking", desc: "Track lost revenue. Flag repeat offenders automatically.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>' },
          { title: "Simple Dashboard", desc: "Today, tomorrow, this week. Mobile-first. At a glance.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>' },
          { title: "Revenue Reports", desc: "Daily, weekly, monthly. Know what no-shows cost you.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>' },
        ].map((f) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-mint/10 text-mint transition-all duration-300 group-hover:bg-mint group-hover:text-white">
              <div class="h-5 w-5 transition-transform duration-300 group-hover:scale-110" set:html={f.icon} />
            </div>
            <h3 class="font-bold text-charcoal">{f.title}</h3>
            <p class="mt-1 text-sm leading-relaxed text-gray-500">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI Receptionist -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2">
        <div>
          <span class="inline-block rounded-lg bg-mint/10 px-3 py-1 text-xs font-bold uppercase tracking-widest text-mint-dark">AI Receptionist</span>
          <h2 class="mt-4 text-3xl font-black text-charcoal sm:text-4xl">Meet Mint, your AI receptionist</h2>
          <p class="mt-4 leading-relaxed text-gray-500">Handles bookings, confirmations, cancellations and FAQs over WhatsApp. 24/7. In plain English.</p>
          <ul class="mt-6 space-y-3">
            {["Confirms and reminds clients automatically", "Handles cancellations and rescheduling with your rules", "Answers questions about services and availability", "Escalates to a human when needed"].map((item) => (
              <li class="flex items-start gap-3 text-sm text-gray-600">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-mint" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <!-- WhatsApp mock -->
        <div class="mx-auto w-full max-w-sm">
          <div class="rounded-2xl border border-gray-200 bg-[#e5ddd5] p-4 shadow-lg">
            <div class="mb-3 flex items-center gap-3 rounded-xl bg-[#075e54] px-4 py-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-full bg-mint text-xs font-bold text-white">M</div>
              <div><p class="text-sm font-semibold text-white">Mint</p><p class="text-[10px] text-green-200">online</p></div>
            </div>
            <div class="space-y-2">
              <div class="ml-auto w-4/5 rounded-lg bg-[#dcf8c6] px-3 py-2"><p class="text-sm text-gray-800">Hi, can I book a massage for Thursday?</p><p class="text-right text-[10px] text-gray-400">14:22</p></div>
              <div class="mr-auto w-4/5 rounded-lg bg-white px-3 py-2"><p class="text-sm text-gray-800">Hi! I've got availability at 10:00, 14:30 and 16:00 on Thursday. Which works best for you?</p><p class="text-right text-[10px] text-gray-400">14:22</p></div>
              <div class="ml-auto w-4/5 rounded-lg bg-[#dcf8c6] px-3 py-2"><p class="text-sm text-gray-800">14:30 please</p><p class="text-right text-[10px] text-gray-400">14:23</p></div>
              <div class="mr-auto w-4/5 rounded-lg bg-white px-3 py-2"><p class="text-sm text-gray-800">Done! You're booked in for Thursday at 14:30 for a 60-minute massage with Sarah. I'll send a reminder the day before.</p><p class="text-right text-[10px] text-gray-400">14:23</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">Integrations</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Connects to what you already use</h2>
      </div>
      <div class="mx-auto mt-14 grid max-w-3xl grid-cols-2 gap-6 sm:grid-cols-3 md:grid-cols-5">
        {[
          { name: "WhatsApp", desc: "Bookings and reminders" },
          { name: "Google", desc: "Maps and reviews" },
          { name: "Instagram", desc: "Booking link in bio" },
          { name: "Facebook", desc: "Book Now button" },
          { name: "Your Website", desc: "Embeddable widget" },
        ].map((int) => (
          <div class="flex flex-col items-center rounded-xl border border-gray-100 bg-gray-50 p-5 text-center transition-all duration-300 hover:-translate-y-1 hover:shadow-md">
            <div class="flex h-12 w-12 items-center justify-center rounded-full bg-white text-sm font-bold text-charcoal shadow-sm">{int.name.charAt(0)}</div>
            <p class="mt-3 text-sm font-semibold text-charcoal">{int.name}</p>
            <p class="mt-1 text-xs text-gray-400">{int.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="bg-white py-20" id="pricing">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">Pricing</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Simple Pricing. No Surprises.</h2>
        <p class="mx-auto mt-4 max-w-lg text-gray-500">No commission. No per-booking fees. No contracts. Cancel anytime.</p>
      </div>
      <div class="mx-auto mt-14 grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Solo -->
        <div class="relative flex flex-col rounded-2xl border-2 border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <h3 class="text-center text-lg font-bold text-charcoal">Solo</h3>
          <p class="mt-1 text-center text-sm text-gray-500">For individual barbers & hairdressers</p>
          <p class="mt-4 text-center"><span class="text-4xl font-black text-charcoal">&pound;9</span><span class="text-sm text-gray-400"> /month</span></p>
          <ul class="mt-6 flex-1 space-y-3">
            {["1 staff member", "Unlimited bookings", "WhatsApp notifications", "Online booking page", "Auto-rebooking", "Gift vouchers"].map((f) => (
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <svg class="h-4 w-4 flex-shrink-0 text-mint" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/get-started/" class="mt-8 block rounded-lg border-2 border-charcoal py-3 text-center text-sm font-semibold text-charcoal transition-all duration-200 hover:bg-charcoal hover:text-white">Get Started</a>
        </div>

        <!-- Shop -->
        <div class="relative flex flex-col rounded-2xl border-2 border-mint bg-mint/5 p-8 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-mint px-4 py-1 text-xs font-bold uppercase text-white">Most Popular</div>
          <h3 class="text-center text-lg font-bold text-charcoal">Shop</h3>
          <p class="mt-1 text-center text-sm text-gray-500">For salons & barbershops with a team</p>
          <p class="mt-4 text-center"><span class="text-4xl font-black text-charcoal">&pound;19</span><span class="text-sm text-gray-400"> /month</span></p>
          <ul class="mt-6 flex-1 space-y-3">
            {["Unlimited staff", "Unlimited bookings", "Everything in Solo", "Chair rental listing", "Staff substitution", "Discovery & aggregation", "Holiday & sick day management"].map((f) => (
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <svg class="h-4 w-4 flex-shrink-0 text-mint" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/get-started/" class="mt-8 block rounded-lg bg-mint py-3 text-center text-sm font-semibold text-white transition-all duration-200 hover:bg-mint-dark hover:shadow-lg hover:shadow-mint/25">Get Started</a>
        </div>

        <!-- Website -->
        <div class="relative flex flex-col rounded-2xl border-2 border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <h3 class="text-center text-lg font-bold text-charcoal">Website</h3>
          <p class="mt-1 text-center text-sm text-gray-500">Custom website for your shop</p>
          <p class="mt-4 text-center"><span class="text-4xl font-black text-charcoal">&pound;150</span><span class="text-sm text-gray-400"> one-off</span></p>
          <p class="mt-1 text-center text-xs text-gray-400">+ &pound;10/month hosting & updates</p>
          <ul class="mt-6 flex-1 space-y-3">
            {["Professional custom design", "Mobile responsive", "Booking integration built-in", "SEO optimised", "Google Maps & reviews", "Free updates included"].map((f) => (
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <svg class="h-4 w-4 flex-shrink-0 text-mint" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/get-started/" class="mt-8 block rounded-lg border-2 border-charcoal py-3 text-center text-sm font-semibold text-charcoal transition-all duration-200 hover:bg-charcoal hover:text-white">Get a Website</a>
        </div>
      </div>

    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">FAQ</p>
        <h2 class="mt-2 text-3xl font-black text-charcoal sm:text-4xl">Frequently asked questions</h2>
      </div>
      <div class="mx-auto mt-14 max-w-2xl">
        {faqItems.map((faq) => (
          <details class="group border-b border-gray-200">
            <summary class="flex cursor-pointer items-center justify-between gap-4 py-5 text-sm font-semibold text-charcoal transition-colors duration-200 hover:text-mint [&::-webkit-details-marker]:hidden">
              <span>{faq.q}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-gray-400 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="none"><path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </summary>
            <div class="pb-5"><p class="text-sm leading-relaxed text-gray-500">{faq.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
