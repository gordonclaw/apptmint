---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact | Apptmint" description="Get in touch with the Apptmint team. Book a demo, ask a question, or request a callback.">

  <!-- Header -->
  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">Contact</p>
        <h1 class="mt-4 text-4xl font-black text-white sm:text-5xl">Let's talk</h1>
        <p class="mt-6 text-lg leading-relaxed text-gray-400">Whether you want a demo, have a question, or are ready to get started -- we'd like to hear from you.</p>
      </div>
    </div>
  </section>

  <!-- Form + info -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-5">

        <!-- Left: contact info -->
        <div class="lg:col-span-2">
          <h2 class="text-2xl font-black text-charcoal">Get in touch</h2>
          <p class="mt-4 leading-relaxed text-gray-500">Fill in the form and our team will get back to you within one working day. For urgent queries, email us directly.</p>

          <div class="mt-10 space-y-6">
            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-mint/10 text-mint">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-charcoal">Email</p>
                <p class="mt-1 text-sm text-gray-500">hello@apptmint.co.uk</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-mint/10 text-mint">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-charcoal">Response Time</p>
                <p class="mt-1 text-sm text-gray-500">Within 1 working day</p>
              </div>
            </div>

            <div class="flex items-start gap-4">
              <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-mint/10 text-mint">
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              </div>
              <div>
                <p class="text-sm font-semibold text-charcoal">Book a Demo</p>
                <p class="mt-1 text-sm text-gray-500">We offer 30-minute live demos where we walk through the platform using your specific use case. Just mention it in your message.</p>
              </div>
            </div>
          </div>

          <div class="mt-10 rounded-2xl border border-gray-100 bg-gray-50 p-6">
            <h3 class="text-sm font-bold text-charcoal">What happens next?</h3>
            <ol class="mt-4 space-y-3">
              {["We review your message and requirements", "A team member responds within one working day", "If you requested a demo, we schedule a 30-minute call", "We help you get set up -- free onboarding on all plans"].map((step, i) => (
                <li class="flex items-start gap-3 text-sm text-gray-500">
                  <span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-mint text-xs font-bold text-white">{i + 1}</span>
                  {step}
                </li>
              ))}
            </ol>
          </div>
        </div>

        <!-- Right: form -->
        <div class="lg:col-span-3">
          <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
            <input type="hidden" name="form-name" value="contact" />
            <p class="hidden">
              <label>Don't fill this out if you're human: <input name="bot-field" /></label>
            </p>

            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div>
                <label for="name" class="block text-sm font-medium text-charcoal">Name</label>
                <input type="text" id="name" name="name" required class="mt-1.5 block w-full rounded-lg border border-gray-200 px-4 py-3 text-sm text-charcoal placeholder-gray-400 transition-colors duration-200 focus:border-mint focus:outline-none focus:ring-1 focus:ring-mint" placeholder="Your full name" />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-charcoal">Email</label>
                <input type="email" id="email" name="email" required class="mt-1.5 block w-full rounded-lg border border-gray-200 px-4 py-3 text-sm text-charcoal placeholder-gray-400 transition-colors duration-200 focus:border-mint focus:outline-none focus:ring-1 focus:ring-mint" placeholder="you@example.com" />
              </div>
            </div>

            <div class="mt-6">
              <label for="business" class="block text-sm font-medium text-charcoal">Business Name</label>
              <input type="text" id="business" name="business" class="mt-1.5 block w-full rounded-lg border border-gray-200 px-4 py-3 text-sm text-charcoal placeholder-gray-400 transition-colors duration-200 focus:border-mint focus:outline-none focus:ring-1 focus:ring-mint" placeholder="Your business name" />
            </div>

            <div class="mt-6">
              <label for="vertical" class="block text-sm font-medium text-charcoal">Your Role / Industry</label>
              <select id="vertical" name="vertical" class="mt-1.5 block w-full rounded-lg border border-gray-200 px-4 py-3 text-sm text-charcoal transition-colors duration-200 focus:border-mint focus:outline-none focus:ring-1 focus:ring-mint">
                <option value="">Select your industry</option>
                <option value="physiotherapy">Physiotherapy</option>
                <option value="psychology">Psychology / Therapy</option>
                <option value="beauty-hair">Beauty / Hair</option>
                <option value="personal-training">Personal Training</option>
                <option value="massage">Massage Therapy</option>
                <option value="dental">Dental</option>
                <option value="chiropractic">Chiropractic</option>
                <option value="osteopathy">Osteopathy</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="mt-6">
              <label for="message" class="block text-sm font-medium text-charcoal">Message</label>
              <textarea id="message" name="message" rows="5" required class="mt-1.5 block w-full rounded-lg border border-gray-200 px-4 py-3 text-sm text-charcoal placeholder-gray-400 transition-colors duration-200 focus:border-mint focus:outline-none focus:ring-1 focus:ring-mint" placeholder="Tell us about your business and what you're looking for. If you'd like a demo, let us know your preferred times."></textarea>
            </div>

            <div class="mt-8">
              <button type="submit" class="w-full rounded-lg bg-mint px-8 py-4 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-mint-dark hover:shadow-lg hover:shadow-mint/25">Send Message</button>
            </div>

            <p class="mt-4 text-center text-xs text-gray-400">By submitting this form you agree to our <a href="/privacy/" class="text-mint hover:text-mint-dark">Privacy Policy</a>.</p>
          </form>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
