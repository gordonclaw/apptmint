---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Features | Apptmint" description="WhatsApp bookings, auto-rebooking, reminders, gift vouchers, chair rental, no-show tracking and more. Built for UK barbers and hairdressers.">

  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">Features</p>
        <h1 class="mt-4 text-4xl font-black text-white sm:text-5xl">What you get with Apptmint</h1>
        <p class="mt-6 text-lg leading-relaxed text-gray-400">Simple tools that save you time and fill your chairs.</p>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { title: "WhatsApp Bookings", desc: "Customers book, confirm and reschedule on WhatsApp. No app downloads, no accounts. Just a message.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>' },
          { title: "Online Booking Page", desc: "Your own booking page, live 24/7. Share the link on Instagram, Facebook, or your Google listing.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>' },
          { title: "Auto-Rebooking", desc: "Set recurring appointments. Every 4 weeks, every 6 weeks. Clients never need to remember to call.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>' },
          { title: "WhatsApp Reminders", desc: "Automatic reminder the day before. One tap to confirm. Cuts no-shows significantly.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>' },
          { title: "Gift Vouchers", desc: "Sell gift vouchers online. Customers buy them for birthdays and holidays. Redeem at your shop.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="8" width="18" height="13" rx="2"/><path d="M12 8V21"/><path d="M3 12h18"/><path d="M12 8c-2-3-6-3-6 0s4 0 6 0c2-3 6-3 6 0s-4 0-6 0"/></svg>' },
          { title: "Holiday Management", desc: "Log holidays and sick days. Bookings blocked automatically. Affected customers notified in advance.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>' },
          { title: "Sick Day Handling", desc: "Staff calls in sick? One tap to notify all affected customers and offer rebooking or substitutes.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><line x1="12" y1="2" x2="12" y2="4"/></svg>' },
          { title: "Staff Substitution", desc: "Customers pick their preferred barber. If they're off, automatically suggest their chosen substitute.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>' },
          { title: "No-Show Tracking", desc: "Track no-shows and see exactly how much revenue you're losing. Flag repeat offenders automatically.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>' },
          { title: "Chair Rental Marketplace", desc: "Got an empty chair? List it for free. Looking for a chair? Find one nearby. No commission.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8v8M8 12h8"/></svg>' },
          { title: "Smart Discovery", desc: "Your regular barber is fully booked? See available slots at nearby partner shops instantly.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>' },
          { title: "Revenue Reports", desc: "Daily, weekly, monthly revenue at a glance. Know exactly what no-shows are costing you.", icon: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>' },
        ].map((f) => (
          <div class="group rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-mint/10 text-mint transition-all duration-300 group-hover:bg-mint group-hover:text-white">
              <div class="h-5 w-5 transition-transform duration-300 group-hover:scale-110" set:html={f.icon} />
            </div>
            <h3 class="font-bold text-charcoal">{f.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-500">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
      <h2 class="text-3xl font-black text-charcoal sm:text-4xl">More coming soon</h2>
      <p class="mt-4 text-gray-500">CRM, Stripe payments, MTD invoicing, payroll, AI receptionist and more are on the roadmap.</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
        <a href="/get-started/" class="rounded-lg bg-mint px-8 py-4 text-sm font-semibold text-white transition-all duration-200 hover:-translate-y-0.5 hover:bg-mint-dark hover:shadow-lg hover:shadow-mint/25">Start Free Trial</a>
        <a href="/contact/" class="rounded-lg border-2 border-gray-200 px-8 py-4 text-sm font-semibold text-charcoal transition-all duration-200 hover:border-mint hover:text-mint">Book a Demo</a>
      </div>
    </div>
  </section>
</BaseLayout>
