---
import BaseLayout from "../layouts/BaseLayout.astro";

const comparisonFeatures = [
  { feature: "Staff members", solo: "1", shop: "Unlimited", website: "N/A" },
  { feature: "Unlimited bookings", solo: true, shop: true, website: false },
  { feature: "WhatsApp notifications", solo: true, shop: true, website: false },
  { feature: "Online booking page", solo: true, shop: true, website: true },
  { feature: "Auto-rebooking", solo: true, shop: true, website: false },
  { feature: "Gift vouchers", solo: true, shop: true, website: false },
  { feature: "Chair rental listing", solo: false, shop: true, website: false },
  { feature: "Staff substitution", solo: false, shop: true, website: false },
  { feature: "Discovery & aggregation", solo: false, shop: true, website: false },
  { feature: "Holiday & sick day management", solo: false, shop: true, website: false },
  { feature: "Custom website design", solo: false, shop: false, website: true },
  { feature: "Mobile responsive", solo: false, shop: false, website: true },
  { feature: "SEO optimised", solo: false, shop: false, website: true },
  { feature: "Google Maps & reviews", solo: false, shop: false, website: true },
  { feature: "Booking integration", solo: false, shop: false, website: true },
];
---

<BaseLayout title="Pricing | Apptmint" description="Simple pricing for barbers and hairdressers. Solo plan from £9/month, Shop plan £19/month. No commission, no contracts, cancel anytime.">

  <section class="bg-charcoal py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">Pricing</p>
        <h1 class="mt-4 text-4xl font-black text-white sm:text-5xl">Simple Pricing. No Surprises.</h1>
        <p class="mt-6 text-lg leading-relaxed text-gray-400">No commission. No per-booking fees. No contracts. Cancel anytime.</p>
      </div>
    </div>
  </section>

  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3">
        <!-- Solo -->
        <div class="relative flex flex-col rounded-2xl border-2 border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <h3 class="text-center text-lg font-bold text-charcoal">Solo</h3>
          <p class="mt-1 text-center text-sm text-gray-500">For individual barbers & hairdressers</p>
          <p class="mt-4 text-center"><span class="text-4xl font-black text-charcoal">&pound;9</span><span class="text-sm text-gray-400"> /month</span></p>
          <ul class="mt-6 flex-1 space-y-3">
            {["1 staff member", "Unlimited bookings", "WhatsApp notifications", "Online booking page", "Auto-rebooking", "Gift vouchers"].map((f) => (
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <svg class="h-4 w-4 flex-shrink-0 text-mint" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/get-started/" class="mt-8 block rounded-lg border-2 border-charcoal py-3 text-center text-sm font-semibold text-charcoal transition-all duration-200 hover:bg-charcoal hover:text-white">Get Started</a>
        </div>

        <!-- Shop -->
        <div class="relative flex flex-col rounded-2xl border-2 border-mint bg-mint/5 p-8 shadow-lg transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2 rounded-full bg-mint px-4 py-1 text-xs font-bold uppercase text-white">Most Popular</div>
          <h3 class="text-center text-lg font-bold text-charcoal">Shop</h3>
          <p class="mt-1 text-center text-sm text-gray-500">For salons & barbershops with a team</p>
          <p class="mt-4 text-center"><span class="text-4xl font-black text-charcoal">&pound;29</span><span class="text-sm text-gray-400"> /month</span></p>
          <ul class="mt-6 flex-1 space-y-3">
            {["Unlimited staff", "Unlimited bookings", "Everything in Solo", "Chair rental listing", "Staff substitution", "Discovery & aggregation", "Holiday & sick day management"].map((f) => (
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <svg class="h-4 w-4 flex-shrink-0 text-mint" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/get-started/" class="mt-8 block rounded-lg bg-mint py-3 text-center text-sm font-semibold text-white transition-all duration-200 hover:bg-mint-dark hover:shadow-lg hover:shadow-mint/25">Get Started</a>
        </div>

        <!-- Website -->
        <div class="relative flex flex-col rounded-2xl border-2 border-gray-100 bg-white p-8 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
          <h3 class="text-center text-lg font-bold text-charcoal">Website</h3>
          <p class="mt-1 text-center text-sm text-gray-500">Custom website for your shop</p>
          <p class="mt-4 text-center"><span class="text-4xl font-black text-charcoal">&pound;150</span><span class="text-sm text-gray-400"> one-off</span></p>
          <p class="mt-1 text-center text-xs text-gray-400">+ &pound;10/month hosting & updates</p>
          <ul class="mt-6 flex-1 space-y-3">
            {["Professional custom design", "Mobile responsive", "Booking integration built-in", "SEO optimised", "Google Maps & reviews", "Free updates included"].map((f) => (
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <svg class="h-4 w-4 flex-shrink-0 text-mint" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                {f}
              </li>
            ))}
          </ul>
          <a href="/get-started/" class="mt-8 block rounded-lg border-2 border-charcoal py-3 text-center text-sm font-semibold text-charcoal transition-all duration-200 hover:bg-charcoal hover:text-white">Get a Website</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Feature comparison -->
  <section class="bg-gray-50 py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">Compare Plans</p>
        <h2 class="mt-4 text-3xl font-black text-charcoal sm:text-4xl">Full feature breakdown</h2>
      </div>
      <div class="mx-auto mt-14 max-w-4xl overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b-2 border-gray-200">
              <th class="pb-4 pr-4 font-semibold text-charcoal">Feature</th>
              <th class="pb-4 px-4 text-center font-semibold text-charcoal">Solo</th>
              <th class="pb-4 px-4 text-center font-semibold text-mint-dark">Shop</th>
              <th class="pb-4 pl-4 text-center font-semibold text-charcoal">Website</th>
            </tr>
          </thead>
          <tbody>
            {comparisonFeatures.map((row) => (
              <tr class="border-b border-gray-200">
                <td class="py-3 pr-4 text-gray-600">{row.feature}</td>
                {[row.solo, row.shop, row.website].map((val) => (
                  <td class="py-3 px-4 text-center">
                    {val === true ? (
                      <svg class="mx-auto h-5 w-5 text-mint" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    ) : val === false ? (
                      <span class="text-gray-300">-</span>
                    ) : (
                      <span class="text-gray-600">{val}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-bold uppercase tracking-[0.2em] text-mint">Questions</p>
        <h2 class="mt-4 text-3xl font-black text-charcoal sm:text-4xl">Pricing FAQ</h2>
      </div>
      <div class="mx-auto mt-14 max-w-2xl">
        {[
          { q: "Are there any setup fees?", a: "No. Sign up and start using it. Free onboarding included." },
          { q: "Do you charge per appointment?", a: "No. All plans include unlimited appointments. No per-booking fees, no commission." },
          { q: "Can I cancel at any time?", a: "Yes. No lock-in contracts. Cancel whenever you want and your plan stays active until the end of the billing period." },
          { q: "What's included in the website add-on?", a: "A custom-designed, mobile-responsive website with your branding, booking integration, Google Maps, reviews, and basic SEO. We build it, you own it." },
          { q: "Can I upgrade later?", a: "Yes. Move from Solo to Shop at any time. You only pay the difference for the rest of your billing period." },
          { q: "Is there a free trial?", a: "Yes. 30 days, full access, no credit card required." },
        ].map((faq) => (
          <details class="group border-b border-gray-200">
            <summary class="flex cursor-pointer items-center justify-between gap-4 py-5 text-sm font-semibold text-charcoal transition-colors duration-200 hover:text-mint [&::-webkit-details-marker]:hidden">
              <span>{faq.q}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-gray-400 transition-transform duration-200 group-open:rotate-180" viewBox="0 0 20 20" fill="none"><path d="M6 8l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
            </summary>
            <div class="pb-5"><p class="text-sm leading-relaxed text-gray-500">{faq.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
